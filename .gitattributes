# Normalize line endings to LF on commit
* text=auto eol=lf

# Force LF for scripts
*.sh text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Force CRLF for Windows-specific files
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line-ending conversion
*.onnx binary
*.bin binary
*.pkl binary
*.pth binary
*.safetensors binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.tar binary
