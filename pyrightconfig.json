{
  "include": ["src/floudsonnx"],
  "exclude": [
    "**/__pycache__",
    ".venv",
    "build",
    "dist",
    "src/floudsonnx.egg-info"
  ],
  "pythonVersion": "3.11",
  "venvPath": ".",
  "venv": ".venv",
  "typeCheckingMode": "basic",
  "reportMissingImports": false,
  "reportMissingTypeStubs": false,
  "reportUnusedImport": true,
  "reportUnusedVariable": true,
  "reportDuplicateImport": true
}
